      #search{border:1px solid #D8D8D8;background:#fff url(http://1.bp.blogspot.com/-jCeDKl35XuU/TyBCBN4SvwI/AAAAAAAABaw/9qzgok4AFqU/s000/search.png) 99% 50% no-repeat;text-align:left;padding:6px 24px 6px 6px}
